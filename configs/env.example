# LoveAdvisor V3 - Environment Variables Example
# Copy this file to .env in the project root and fill in your API keys

# Application Settings
ENVIRONMENT=development
DEBUG=True

# LLM Provider Configuration
LLM_PROVIDER=deepseek  # Options: mock, deepseek, openai, anthropic
LLM_DEFAULT_MODEL=deepseek-chat
LLM_DEFAULT_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Provider API Keys
# Uncomment and fill in the keys for providers you want to use

# DeepSeek API Key (from https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key (from https://platform.openai.com/)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Legacy Coze Configuration (V2.5 backward compatibility)
COZE_API_TOKEN=pat_QUELD2jsDVTLlMntEAOCuqSXNyUGx1U4Eeh8Sg1jxpV8Qhg4rBQUuSetowoUOwz7

# I1 Image-to-Text Vision Model Configuration
# Now using OCR.space as the single provider for OCR capabilities
# Sign up for free API key at https://ocr.space/ocrapi (500 requests/day/IP free)
I1_VISION_API_KEY=your_ocr_space_api_key_here
I1_VISION_MODEL=2
I1_VISION_LANGUAGE=chs
I1_VISION_BASE_URL=https://api.ocr.space
# DashScope (Aliyun) Configuration for Qwen-OCR
# Get API key from https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_OCR_MODEL=qwen-vl-ocr
QWEN_OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
